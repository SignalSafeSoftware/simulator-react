{
  "name": "@signalsafe/simulator-react",
  "version": "0.1.5",
  "type": "module",
  "description": "Reusable React device simulator shell, session state, and utilities (no routing or API).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SignalSafeSoftware/simulator-react.git"
  },
  "bugs": {
    "url": "https://github.com/SignalSafeSoftware/simulator-react/issues"
  },
  "homepage": "https://github.com/SignalSafeSoftware/simulator-react#readme",
  "keywords": [
    "react",
    "simulator",
    "tree-spec",
    "decision-tree",
    "scenario",
    "training",
    "phishing",
    "security-awareness",
    "typescript",
    "device-simulator",
    "session",
    "signalsafe"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./utils/validateSimulatorPayload": {
      "types": "./dist/utils/validateSimulatorPayload.d.ts",
      "import": "./dist/utils/validateSimulatorPayload.js",
      "default": "./dist/utils/validateSimulatorPayload.js"
    },
    "./utils/simulatorPreviewReport": {
      "types": "./dist/utils/simulatorPreviewReport.d.ts",
      "import": "./dist/utils/simulatorPreviewReport.js",
      "default": "./dist/utils/simulatorPreviewReport.js"
    },
    "./utils/simulatorRealismChecks": {
      "types": "./dist/utils/simulatorRealismChecks.d.ts",
      "import": "./dist/utils/simulatorRealismChecks.js",
      "default": "./dist/utils/simulatorRealismChecks.js"
    },
    "./utils/previewFallbackWorld": {
      "types": "./dist/utils/previewFallbackWorld.d.ts",
      "import": "./dist/utils/previewFallbackWorld.js",
      "default": "./dist/utils/previewFallbackWorld.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.13.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsx ./scripts/fix-node-esm-relative-imports.ts dist",
    "typecheck": "tsc --noEmit",
    "pack:local": "npm pack --pack-destination ../../dist/reusable-npm",
    "release:check": "node ../../scripts/run-private-package-release-checks.mjs --mode prepublish",
    "release:verify": "node ../../scripts/run-private-package-release-checks.mjs --mode postpublish",
    "publish:preflight": "node ../../scripts/check-private-registry-preflight.mjs --scope @signalsafe",
    "publish:dry-run": "npm publish --dry-run",
    "publish:verify": "node ../../scripts/check-private-package-postpublish.mjs --scope @signalsafe --package @signalsafe/simulator-react --version $npm_package_version",
    "pack:check": "node ../../scripts/check-package-tarball.mjs --tgz \"../../dist/reusable-npm/signalsafe-simulator-react-$npm_package_version.tgz\" --expect package/dist/index.js --expect package/dist/index.d.ts --expect package/package.json --expect package/README.md",
    "smoke:external": "node ../../scripts/smoke-simulator-react-external-consumer.mjs",
    "smoke:published": "node ../../scripts/smoke-simulator-react-external-consumer.mjs --source registry",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:monorepo": "cd ../../frontend && yarn vitest run --config vitest.simulator-react.config.ts"
  },
  "dependencies": {
    "@signalsafe/simulator-core": "^0.1.4",
    "@signalsafe/tree-spec": "^0.3.1"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-bootstrap": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/react-test-renderer": "^18.3.0",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.2",
    "react-dom": "^18.3.1",
    "react-test-renderer": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.4.2",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
