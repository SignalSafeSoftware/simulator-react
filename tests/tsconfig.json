{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "..",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@signalsafe/tree-spec": ["../tree-spec/src/index.ts"],
      "@signalsafe/tree-spec/*": ["../tree-spec/src/*"],
      "@signalsafe/simulator-core": ["../simulator-core/src/index.ts"],
      "@signalsafe/simulator-core/*": ["../simulator-core/src/*"],
      "@signalsafe/simulator-react": ["../src/index.ts"],
      "@signalsafe/simulator-react/*": ["../src/*"],
      "@workspace-simulator-test-support/*": ["./support/*"],
      "react": ["../node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["../node_modules/@types/react/jsx-runtime.d.ts"],
      "react-dom": ["../node_modules/@types/react-dom/index.d.ts"],
      "react-bootstrap": ["../node_modules/react-bootstrap/esm/index.d.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
